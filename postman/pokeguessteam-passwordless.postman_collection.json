{
  "info": {
    "_postman_id": "d53e86ea-f2bd-4d8a-b930-e44ec21cba26",
    "name": "PokeTeamGuess API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "PokeTeamGuess — autenticação (sessão + session binding), perfil, Pokédex e partidas BOT.\n\nFluxo sugerido: Register → Login → Pokedex (preenche IDs) → Game criar partida → Palpite / Estado.\n\nImportante: mantenha o cookie de sessão (Postman envia automaticamente após o login no mesmo ambiente)."
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept-Language", "value": "pt-BR" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"treinador1\",\n  \"email\": \"treinador1@example.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept-Language", "value": "pt-BR" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login\": \"treinador1@example.com\",\n  \"password\": \"123456\"\n}"
            },
            "description": "Campo `login`: e-mail OU nome de usuário (não use apenas o campo `email`).",
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Session (status)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept-Language", "value": "pt-BR" }],
            "url": "{{baseUrl}}/auth/session"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "const j = pm.response.json();",
                  "pm.test(\"JSON com authenticated\", function () {",
                  "    pm.expect(j).to.be.an(\"object\");",
                  "    pm.expect(j).to.have.property(\"authenticated\");",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept-Language", "value": "pt-BR" }],
            "url": "{{baseUrl}}/auth/logout"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Profile",
      "item": [
        {
          "name": "Me (resumo)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept-Language", "value": "pt-BR" }],
            "url": "{{baseUrl}}/api/profile/me"
          }
        },
        {
          "name": "Collection (inventário)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept-Language", "value": "pt-BR" }],
            "url": "{{baseUrl}}/api/profile/collection"
          }
        }
      ]
    },
    {
      "name": "Game",
      "item": [
        {
          "name": "Pokedex (listar)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept-Language", "value": "pt-BR" }],
            "url": "{{baseUrl}}/api/pokedex"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "const list = pm.response.json();",
                  "if (Array.isArray(list) && list.length >= 6) {",
                  "    for (let i = 0; i < 6; i++) {",
                  "        pm.collectionVariables.set(\"pokemonId\" + (i + 1), list[i].id);",
                  "    }",
                  "    pm.collectionVariables.set(\"guessPokemonId\", list[0].id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Criar partida BOT",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept-Language", "value": "pt-BR" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"playerTeamPokemonIds\": [\n    \"{{pokemonId1}}\",\n    \"{{pokemonId2}}\",\n    \"{{pokemonId3}}\",\n    \"{{pokemonId4}}\",\n    \"{{pokemonId5}}\",\n    \"{{pokemonId6}}\"\n  ]\n}"
            },
            "description": "Execute **Pokedex** antes para preencher pokemonId1…6, ou defina as variáveis da coleção manualmente.",
            "url": "{{baseUrl}}/api/game/matches/bot"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "const data = pm.response.json();",
                  "if (data && data.matchId) {",
                  "    pm.collectionVariables.set(\"matchId\", data.matchId);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Palpite",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept-Language", "value": "pt-BR" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"guessedPokemonId\": \"{{guessPokemonId}}\"\n}"
            },
            "url": "{{baseUrl}}/api/game/matches/{{matchId}}/guess"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Estado da partida",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept-Language", "value": "pt-BR" }],
            "url": "{{baseUrl}}/api/game/matches/{{matchId}}"
          }
        }
      ]
    },
    {
      "name": "Session binding (teste)",
      "item": [
        {
          "name": "GET /api/me (ok)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept-Language", "value": "pt-BR" }],
            "url": "{{baseUrl}}/api/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200 quando logado\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/me (outro User-Agent → 401)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept-Language", "value": "pt-BR" },
              { "key": "User-Agent", "value": "Postman-SessionBinding-Test/1.0" }
            ],
            "url": "{{baseUrl}}/api/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 401\", function () {",
                  "    pm.response.to.have.status(401);",
                  "});",
                  "const j = pm.response.json();",
                  "pm.test(\"Corpo com code e message\", function () {",
                  "    pm.expect(j).to.have.property(\"code\");",
                  "    pm.expect(j).to.have.property(\"message\");",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "matchId", "value": "" },
    { "key": "pokemonId1", "value": "" },
    { "key": "pokemonId2", "value": "" },
    { "key": "pokemonId3", "value": "" },
    { "key": "pokemonId4", "value": "" },
    { "key": "pokemonId5", "value": "" },
    { "key": "pokemonId6", "value": "" },
    { "key": "guessPokemonId", "value": "" }
  ]
}
