{
  "info": {
    "_postman_id": "d53e86ea-f2bd-4d8a-b930-e44ec21cba26",
    "name": "PokeTeamGuess API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "PokeTeamGuess — API REST.\n\n**Auth:** sessão HTTP + session binding (cookie `JSESSIONID`, mesmo User-Agent).\n\n**Ordem sugerida:** Register → Login → Session → Change password / Change username → Logout.\n\n**Register** responde `{ \"userId\", \"email\", \"username\" }` (sem verificação por e-mail).\n\nDepois do Login, use as mesmas requests na coleção (cookie automático no ambiente)."
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept-Language", "value": "pt-BR" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"treinador1\",\n  \"email\": \"treinador1@example.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": "{{baseUrl}}/auth/register",
            "description": "Body: `username`, `email`, `password` (mín. 6 caracteres)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "const j = pm.response.json();",
                  "pm.test(\"Resposta register\", function () {",
                  "    pm.expect(j).to.have.property(\"userId\");",
                  "    pm.expect(j).to.have.property(\"email\");",
                  "    pm.expect(j).to.have.property(\"username\");",
                  "});",
                  "if (j.email) {",
                  "    pm.collectionVariables.set(\"authEmail\", j.email);",
                  "}",
                  "if (j.username) {",
                  "    pm.collectionVariables.set(\"authUsername\", j.username);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept-Language", "value": "pt-BR" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login\": \"{{authEmail}}\",\n  \"password\": \"123456\"\n}"
            },
            "description": "`login`: e-mail OU username (ex.: `{{authEmail}}` ou `{{authUsername}}`). Depois do Register, rode este request para obter o cookie de sessão.",
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Session (status)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept-Language", "value": "pt-BR" }],
            "url": "{{baseUrl}}/auth/session",
            "description": "GET público. Confere sessão: `authenticated`, opcionalmente id em sessão."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "const j = pm.response.json();",
                  "pm.test(\"JSON com authenticated\", function () {",
                  "    pm.expect(j).to.be.an(\"object\");",
                  "    pm.expect(j).to.have.property(\"authenticated\");",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Change password (logado)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept-Language", "value": "pt-BR" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"123456\",\n  \"newPassword\": \"654321\"\n}"
            },
            "description": "PATCH protegido: sessão + session binding. Mesmo User-Agent do Login.",
            "url": "{{baseUrl}}/auth/password"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Change username (logado)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept-Language", "value": "pt-BR" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"newUsername\": \"treinador2\",\n  \"password\": \"123456\"\n}"
            },
            "description": "Confirma com a senha atual. Requer sessão + session binding.",
            "url": "{{baseUrl}}/auth/username"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept-Language", "value": "pt-BR" }],
            "url": "{{baseUrl}}/auth/logout"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Profile",
      "item": [
        {
          "name": "Me (resumo)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept-Language", "value": "pt-BR" }],
            "url": "{{baseUrl}}/api/profile/me"
          }
        },
        {
          "name": "Collection (inventário)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept-Language", "value": "pt-BR" }],
            "url": "{{baseUrl}}/api/profile/collection",
            "description": "Resposta: `items` (lista de `pokeballType` + `quantity`), `pokeballFragments`, `fragmentsPerPokeBall` (10)."
          }
        }
      ]
    },
    {
      "name": "Pokedex",
      "item": [
        {
          "name": "Listar (paginado)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept-Language", "value": "pt-BR" }],
            "url": "{{baseUrl}}/api/pokedex?page=0&size=20",
            "description": "Query opcional: `page` (base 0, default 0), `size` (default 20, máx. 100). Resposta: `content`, `page`, `size`, `totalElements`, `totalPages`, `first`, `last`."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test(\"Paginação\", function () {",
                  "    pm.expect(body).to.have.property(\"content\");",
                  "    pm.expect(body.content).to.be.an(\"array\");",
                  "    pm.expect(body).to.have.property(\"page\");",
                  "    pm.expect(body).to.have.property(\"size\");",
                  "    pm.expect(body).to.have.property(\"totalElements\");",
                  "    pm.expect(body).to.have.property(\"totalPages\");",
                  "    pm.expect(body).to.have.property(\"first\");",
                  "    pm.expect(body).to.have.property(\"last\");",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Session binding (teste)",
      "item": [
        {
          "name": "GET /api/me (ok)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept-Language", "value": "pt-BR" }],
            "description": "Esperado: `authenticatedAs` (e-mail no principal), `userId`, `username`, `email`.",
            "url": "{{baseUrl}}/api/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200 quando logado\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "const j = pm.response.json();",
                  "pm.test(\"Campos /api/me\", function () {",
                  "    pm.expect(j).to.have.property(\"authenticatedAs\");",
                  "    pm.expect(j).to.have.property(\"userId\");",
                  "    pm.expect(j).to.have.property(\"username\");",
                  "    pm.expect(j).to.have.property(\"email\");",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/me (outro User-Agent → 401)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept-Language", "value": "pt-BR" },
              { "key": "User-Agent", "value": "Postman-SessionBinding-Test/1.0" }
            ],
            "url": "{{baseUrl}}/api/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 401\", function () {",
                  "    pm.response.to.have.status(401);",
                  "});",
                  "const j = pm.response.json();",
                  "pm.test(\"Corpo com code e message\", function () {",
                  "    pm.expect(j).to.have.property(\"code\");",
                  "    pm.expect(j).to.have.property(\"message\");",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "authEmail", "value": "treinador1@example.com" },
    { "key": "authUsername", "value": "treinador1" }
  ]
}
